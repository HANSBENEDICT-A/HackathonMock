<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OrangeHRM Suite">

    <listeners>
        <listener class-name="com.krct.listeners.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.krct.LoginTest"/>
        </classes>
    </test>

    <test name="Employee Tests">
        <classes>
            <class name="com.krct.EmployeeTest"/>
        </classes>
    </test>

    <test name="Leave Tests">
        <classes>
            <class name="com.krct.LeaveTest"/>
        </classes>
    </test>

    <test name="Admin Tests">
        <classes>
            <class name="com.krct.AdminTest"/>
        </classes>
    </test>

    <test name="Validation Tests">
        <classes>
            <class name="com.krct.ValidationTest"/>
        </classes>
    </test>

</suite>